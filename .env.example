# ─── Environment variables ───
# Copy this file to .env and fill in the real values:
#   cp .env.example .env

# Telegram bot token from @BotFather (REQUIRED)
BOT_TOKEN=123456:replace_with_your_bot_token

# Path to the SQLite database file (optional, default: finance.db)
DB_PATH=finance.db

# Premium custom emoji (optional, default: 1 = on).
# Set to 0 to disable. Rendering requires the bot owner to have Telegram Premium.
PREMIUM_EMOJI=1

# Timezone offset in hours for recorded timestamps (optional, default: 4)
TZ_OFFSET_HOURS=4
